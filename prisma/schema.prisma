generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum AutoReplyRuleMatchType {
  EXACT
  CONTAINS
}

enum AutoReplyRuleLanguage {
  ANY
  DARIJA
  FRENCH
}

enum WhatsAppProvider {
  CLOUD_API
  BUSINESS_PLATFORM
}

enum WhatsAppConnectionStatus {
  PENDING
  CONNECTED
  REQUIRES_ACTION
  DISCONNECTED
}

enum IncomingMessageProcessingStatus {
  RECEIVED
  MATCHED
  NO_MATCH
  UNSUPPORTED
  DUPLICATE
  FAILED
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  TEMPLATE
}

enum OutgoingMessageStatus {
  PREPARED
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  name           String
  passwordHash   String
  role           UserRole    @default(OWNER)
  workspaceId    String?
  workspace      Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  ownedWorkspace Workspace?  @relation("WorkspaceOwner")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Workspace {
  id                  String               @id @default(cuid())
  name                String
  slug                String               @unique
  ownerId             String               @unique
  owner               User                 @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members             User[]
  subscriptions       Subscription[]
  autoReplyRules      AutoReplyRule[]
  incomingMessageLogs IncomingMessageLog[]
  outgoingMessageLogs OutgoingMessageLog[]
  whatsAppConnection  WhatsAppConnection?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model Plan {
  id                    String         @id @default(cuid())
  slug                  String         @unique
  name                  String
  description           String?
  monthlyPriceMad       Int
  yearlyPriceMad        Int?
  maxRules              Int
  maxMonthlyMessages    Int
  maxWhatsAppConnections Int
  isActive              Boolean        @default(true)
  subscriptions         Subscription[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
}

model Subscription {
  id                     String             @id @default(cuid())
  workspaceId            String
  planId                 String
  status                 SubscriptionStatus @default(TRIALING)
  startsAt               DateTime           @default(now())
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  providerCustomerId     String?            @unique
  providerSubscriptionId String?            @unique
  workspace              Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan                   Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([workspaceId, status])
}

model AutoReplyRule {
  id           String                @id @default(cuid())
  workspaceId  String
  keyword      String
  replyMessage String                @db.Text
  matchType    AutoReplyRuleMatchType @default(CONTAINS)
  language     AutoReplyRuleLanguage @default(ANY)
  category     String?
  priority     Int                   @default(1)
  isActive     Boolean               @default(true)
  workspace    Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  incomingMessageLogs IncomingMessageLog[] @relation("IncomingMatchedRule")
  outgoingMessageLogs OutgoingMessageLog[] @relation("OutgoingMatchedRule")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@unique([workspaceId, keyword, matchType, language])
  @@index([workspaceId, priority])
  @@index([workspaceId, isActive, priority])
  @@index([workspaceId, language, matchType])
  @@index([workspaceId, category])
}

model WhatsAppConnection {
  id                    String                   @id @default(cuid())
  workspaceId           String                   @unique
  label                 String
  phoneNumber           String?
  phoneNumberId         String?                  @unique
  businessAccountId     String?
  provider              WhatsAppProvider         @default(CLOUD_API)
  status                WhatsAppConnectionStatus @default(PENDING)
  providerReference     String?                  @unique
  accessTokenEncrypted  String?                  @db.Text
  verifyTokenEncrypted  String?                  @db.Text
  appSecretEncrypted    String?                  @db.Text
  webhookKey            String                   @unique
  webhookSubscribed     Boolean                  @default(false)
  sendRepliesEnabled    Boolean                  @default(false)
  lastWebhookAt         DateTime?
  lastVerifiedAt        DateTime?
  lastHeartbeatAt       DateTime?
  settings              Json?
  workspace             Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  incomingMessageLogs   IncomingMessageLog[]
  outgoingMessageLogs   OutgoingMessageLog[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([status, webhookSubscribed])
}

model IncomingMessageLog {
  id                   String                        @id @default(cuid())
  workspaceId          String
  whatsAppConnectionId String?
  matchedRuleId        String?
  externalMessageId    String?                       @unique
  senderPhone          String
  recipientPhone       String
  messageType          MessageType                   @default(TEXT)
  content              String?
  normalizedContent    String?
  processingStatus     IncomingMessageProcessingStatus @default(RECEIVED)
  processingReason     String?
  payload              Json?
  receivedAt           DateTime                      @default(now())
  processedAt          DateTime?
  workspace            Workspace                     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  whatsAppConnection   WhatsAppConnection?           @relation(fields: [whatsAppConnectionId], references: [id], onDelete: SetNull)
  matchedRule          AutoReplyRule?                @relation("IncomingMatchedRule", fields: [matchedRuleId], references: [id], onDelete: SetNull)
  createdAt            DateTime                      @default(now())

  @@index([workspaceId, receivedAt(sort: Desc)])
  @@index([workspaceId, processingStatus, receivedAt(sort: Desc)])
  @@index([matchedRuleId])
}

model OutgoingMessageLog {
  id                   String                @id @default(cuid())
  workspaceId          String
  whatsAppConnectionId String?
  matchedRuleId        String?
  externalMessageId    String?               @unique
  recipientPhone       String
  messageType          MessageType           @default(TEXT)
  content              String?
  status               OutgoingMessageStatus @default(PREPARED)
  failureReason        String?
  payload              Json?
  sentAt               DateTime?
  workspace            Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  whatsAppConnection   WhatsAppConnection?   @relation(fields: [whatsAppConnectionId], references: [id], onDelete: SetNull)
  matchedRule          AutoReplyRule?        @relation("OutgoingMatchedRule", fields: [matchedRuleId], references: [id], onDelete: SetNull)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([workspaceId, status, createdAt(sort: Desc)])
  @@index([matchedRuleId])
}
